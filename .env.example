DATABASE_URL="file:./dev.db"
BOT_TOKEN="YOUR_TELEGRAM_BOT_TOKEN"
# Username бота без @ (для ссылок «Приобрести»: t.me/BOT_USERNAME?start=plan_M1…)
BOT_USERNAME="maxvpn_offbot"
# Основной VPN: либо Marzban HTTP API, либо Remnawave (ниже). Если заданы REMNAWAVE_* — они используются для создания/продления вместо MARZBAN_API_URL.
MARZBAN_API_URL="https://your-marzban:port"
MARZBAN_TOKEN=""
MARZBAN_API_URL_2=""
MARZBAN_TOKEN_2=""
# Сервер 2 (rus2) больше не выдаём. Оставить выключенным.
ENABLE_SERVER2=false
# Remnawave wrapper (см. scripts/new-api/new-api.md): только API_ACCESS_KEY, не JWT панели
REMNAWAVE_API_URL="https://api.maxg.ch"
REMNAWAVE_API_KEY=""
# optional: basic | russia
REMNAWAVE_SUBSCRIPTION_TYPE="russia"
# optional: REMNAWAVE_DEVICE_LIMIT=3
MARZBAN_USERNAME="USERNAME"
MARZBAN_PASSWORD="PASSWORD"
PAYMENT_API_URL="https://pal24.pro/api/v1"
PAYMENT_API_TOKEN="YOUR_PAYMENT_TOKEN"
PAYMENT_SHOP_ID="YOUR_SHOP_ID"
PAYMENT_PORT=4000
# Web App API (web.grangy.ru): секрет должен совпадать с тем, что отправляет Web App
WEBAPP_SECRET=your_webapp_secret
# Claim API (сайт → redeem токена)
CLAIM_API_BASE_URL=https://your-site.example
CLAIM_API_KEY=your_internal_secret
# Google Sheets: название листа — "Sheet1" (EN) или "Лист1" (RU)
GOOGLE_SHEETS_SHEET_NAME=Sheet1
