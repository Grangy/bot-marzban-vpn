datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum SubscriptionType {
  FREE
  D7
  M1
  M3
  M6
  M12
  PROMO_10D
}

model User {
  id          Int           @id @default(autoincrement())
  telegramId  String
  chatId      String
  accountName String?
  balance     Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // 👇 новые поля/связи
  promoCode   String?       @unique
  promoActivationsAsOwner   PromoActivation[] @relation("OwnerActivations")
  promoActivationAsUser     PromoActivation?  @relation("UserActivation")
  adminPromoActivations AdminPromoActivation[] // активации админских промокодов
  referralBonusesAsOwner ReferralBonus[] @relation("ReferralBonusOwner") // бонусы от рефералов
  referralBonusesAsActivator ReferralBonus[] @relation("ReferralBonusActivator") // бонусы, которые пользователь принес владельцу

  subscriptions Subscription[]
  topUps         TopUp[]

  noTrafficReminderSentAt DateTime?   // напоминание «купили, но не подключились» (2ч после покупки) отправлено

  @@unique([telegramId, chatId], name: "telegramId_chatId")
  @@index([telegramId])
  @@index([chatId])
}

model PromoActivation {
  id           Int      @id @default(autoincrement())
  codeOwnerId  Int
  activatorId  Int      @unique      // 🔒 один активатор — одна активация любого промо
  createdAt    DateTime @default(now())

  // связи
  codeOwner    User     @relation("OwnerActivations", fields: [codeOwnerId], references: [id])
  activator    User     @relation("UserActivation",   fields: [activatorId], references: [id])

  @@index([codeOwnerId, createdAt])
}


model Subscription {
  id              Int              @id @default(autoincrement())
  type            SubscriptionType
  startDate       DateTime         @default(now())
  endDate         DateTime?
  userId          Int
  user            User             @relation(fields: [userId], references: [id])
  subscriptionUrl String?          // 🔥 основная ссылка (vpn.grangy.ru)
  subscriptionUrl2 String?         // 🔥 вторая ссылка для rus2 (rus2.grangy.ru:8888)
  remnawaveUuid   String?          @unique // UUID в Remnawave Panel (уникален: 1 подписка → 1 пользователь)
  remindExtend12hSentAt DateTime?         // напоминание через 12 часов после привязки (trial/FREE)
  notified3Days            Boolean   @default(false)  // уведомление за 3 дня отправлено
  notified1Day             Boolean   @default(false)  // уведомление за 1 день отправлено
  lastExpiredReminderAt    DateTime?   

  @@index([userId])
  @@index([type, startDate])
}


model TopUp {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  amount     Int
  status     String   @default("PENDING") // PENDING | SUCCESS | FAILED | TIMEOUT
  orderId    String   @unique              // внешний/наш номер заказа
  billId     String?                       // id счета в провайдере
  credited   Boolean  @default(false)      // ✅ зачислено на баланс?
  creditedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  referralBonuses ReferralBonus[] // реферальные бонусы от этого пополнения

  @@index([userId, createdAt])
}

// Админские промокоды (на баланс или на дни)
model AdminPromo {
  id         Int      @id @default(autoincrement())
  code       String   @unique              // уникальный код промокода
  type       String   @default("BALANCE")  // BALANCE - на баланс, DAYS - на дни подписки
  amount     Int?                          // номинал в рублях (для type=BALANCE)
  days       Int?                          // количество дней (для type=DAYS)
  isReusable Boolean  @default(false)      // многоразовый промокод (для блогеров)
  customName String?                       // кастомное название промокода (для отображения)
  usedById   Int?                          // кто использовал (null = не использован, для одноразовых)
  usedAt     DateTime?                     // когда использован (для одноразовых)
  useCount   Int      @default(0)          // количество использований (для многоразовых)
  createdAt  DateTime @default(now())
  createdBy  String?                       // кто создал (telegram id админа)
  
  activations AdminPromoActivation[]      // активации многоразовых промокодов
  
  @@index([code])
  @@index([type, createdAt])
}

// Отслеживание активаций админских промокодов (каждый пользователь может активировать промокод только 1 раз)
model AdminPromoActivation {
  id         Int      @id @default(autoincrement())
  promoId    Int                           // ID промокода
  userId     Int                           // ID пользователя, который активировал
  activatedAt DateTime @default(now())       // когда активировал
  
  promo      AdminPromo @relation(fields: [promoId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  
  @@unique([promoId, userId])              // один пользователь может активировать промокод только один раз
  @@index([promoId])
  @@index([userId])
}

// Реферальные бонусы (20% от пополнений владельцу промокода)
model ReferralBonus {
  id           Int      @id @default(autoincrement())
  codeOwnerId  Int                           // владелец промокода (кто получит бонус)
  activatorId  Int                           // кто пополнил баланс (активатор промокода)
  topupId      Int                           // ID пополнения
  amount       Int                           // сумма пополнения (в копейках)
  bonusAmount  Int                           // 20% от суммы пополнения (в копейках)
  credited     Boolean  @default(false)      // зачислен ли бонус владельцу
  creditedAt   DateTime?                     // когда зачислен
  createdAt    DateTime @default(now())      // когда создан бонус

  // связи
  codeOwner    User     @relation("ReferralBonusOwner", fields: [codeOwnerId], references: [id])
  activator    User     @relation("ReferralBonusActivator", fields: [activatorId], references: [id])
  topup        TopUp    @relation(fields: [topupId], references: [id])

  @@index([codeOwnerId, createdAt])         // для поиска бонусов владельца
  @@index([activatorId])                    // для поиска бонусов активатора
  @@index([topupId])                        // для поиска по пополнению
}


